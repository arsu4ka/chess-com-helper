{
	"name": "Chess.com Helper",
	"description": "A Chrome extension that provides various features to enhance the user experience on Chess.com.",
	"version": "0.1.0",
	"manifest_version": 3,
	"icons": {
		"16": "icons/16.png",
		"32": "icons/32.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	},
	"action": {
		"default_icon": "icons/icon.png",
		"default_title": "Chess.com Helper",
		"default_popup": "popup/index.html"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_security_policy": {
		"extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
	},
	"permissions": ["offscreen", "storage"],
	"content_scripts": [
		{
			"js": ["contentScript.js"],
			"matches": ["https://www.chess.com/*", "https://chess.com/*"],
			"run_at": "document_idle"
		}
	]
}
