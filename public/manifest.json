{
	"name": "Chess.com Helper",
	"description": "A Chrome extension that provides various features to enhance the user experience on Chess.com.",
	"version": "0.1.0",
	"manifest_version": 3,
	"icons": {
		"16": "icons/16.png",
		"32": "icons/32.png",
		"48": "icons/48.png",
		"128": "icons/128.png"
	},
	"action": {
		"default_title": "Chess.com Helper",
		"default_popup": "popup/index.html"
	},
	"background": {
		"service_worker": "background.js"
	},
	"permissions": ["offscreen"],
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["contentScript.js"]
		}
	]
}
